      "source": [
        "# 기존 HUD 렌더링 함수 (Part 9-3과 동일 구조, analyzer만 교체)\n",
        "def denormalize(img_tensor):\n",
        "    mean = np.array([0.485, 0.456, 0.406])\n",
        "    std  = np.array([0.229, 0.224, 0.225])\n",
        "    img  = img_tensor.cpu().numpy().transpose(1, 2, 0)\n",
        "    return np.clip((img * std + mean) * 255, 0, 255).astype(np.uint8)\n",
        "\n",
        "\n",
        "def render_hud_v2(image, danger_result, bio_data, frame_idx=0):\n",
        "    H, W = image.shape[:2]\n",
        "    canvas = image.copy()\n",
        "\n",
        "    GREEN  = (80, 255, 150)\n",
        "    YELLOW = (255, 220, 50)\n",
        "    ORANGE = (255, 140, 30)\n",
        "    RED    = (255, 60, 80)\n",
        "    WHITE  = (240, 245, 255)\n",
        "    DIM    = (140, 160, 180)\n",
        "    PINK   = (255, 100, 140)\n",
        "\n",
        "    level_color = {'SAFE': GREEN, 'CAUTION': YELLOW,\n",
        "                   'WARNING': ORANGE, 'DANGER': RED}.get(danger_result['level'], GREEN)\n",
        "\n",
        "    # 속도 (좌상단)\n",
        "    cv2.putText(canvas, '62', (20, 30), cv2.FONT_HERSHEY_DUPLEX, 0.6, WHITE, 1)\n",
        "    cv2.putText(canvas, 'km/h', (50, 30), cv2.FONT_HERSHEY_SIMPLEX, 0.35, DIM, 1)\n",
        "\n",
        "    # 분석 소스 표시 (LSTM 사용 여부)\n",
        "    src_color = (100, 200, 255) if 'LSTM' in danger_result['source'] else DIM\n",
        "    cv2.putText(canvas, danger_result['source'], (20, H - 10),\n",
        "                cv2.FONT_HERSHEY_SIMPLEX, 0.3, src_color, 1)\n",
        "\n",
        "    # 생체 신호\n",
        "    hr_val  = bio_data['hr']\n",
        "    fat_val = bio_data['fatigue']\n",
        "    hr_color = GREEN if hr_val < 100 else (YELLOW if hr_val < 130 else RED)\n",
        "    fat_color = GREEN if fat_val < 40 else (YELLOW if fat_val < 70 else RED)\n",
        "\n",
        "    cv2.putText(canvas, f'HR:{hr_val:.0f}',   (W-90, H-28), cv2.FONT_HERSHEY_DUPLEX, 0.45, hr_color,  1)\n",
        "    cv2.putText(canvas, f'FAT:{fat_val:.0f}%', (W-90, H-12), cv2.FONT_HERSHEY_DUPLEX, 0.45, fat_color, 1)\n",
        "\n",
        "    # 위험도 (우상단)\n",
        "    score_text = f\"{danger_result['score']:.0f}\"\n",
        "    cv2.putText(canvas, danger_result['level'], (W-90, 22), cv2.FONT_HERSHEY_DUPLEX,  0.5, level_color, 2)\n",
        "    cv2.putText(canvas, score_text,             (W-90, 38), cv2.FONT_HERSHEY_SIMPLEX, 0.4, WHITE, 1)\n",
        "\n",
        "    # 가장자리 위험 글로우\n",
        "    if danger_result['level'] in ('WARNING', 'DANGER'):\n",
        "        pulse = (np.sin(frame_idx * 0.7) + 1) / 2\n",
        "        alpha = 0.2 + pulse * 0.25\n",
        "        overlay = canvas.copy()\n",
        "        for i in range(20):\n",
        "            cv2.line(overlay, (i,0),(i,H), level_color, 1)\n",
        "            cv2.line(overlay, (W-1-i,0),(W-1-i,H), level_color, 1)\n",
        "            cv2.line(overlay, (0,i),(W,i), level_color, 1)\n",
        "            cv2.line(overlay, (0,H-1-i),(W,H-1-i), level_color, 1)\n",
        "        canvas[:] = cv2.addWeighted(overlay, alpha, canvas, 1-alpha, 0)\n",
        "\n",
        "    return canvas\n",
        "\n",
        "\n",
        "print('✅ HUD v2 렌더링 함수 준비 완료')"
      ],
