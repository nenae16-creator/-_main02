      "source": [
        "# ⚙️ Part 6: Optimizer & 학습/검증 함수\n",
        "\n",
        "**SegFormer에 맞는 설정:**\n",
        "- 백본(encoder)과 디코더 head의 학습률을 다르게 설정 (Layer-wise LR decay)\n",
        "- 백본은 작은 lr로 pretrained weight 보존, head는 큰 lr로 빠르게 적응"
      ],
      "id": "o-flpFmaQAda"
    },
    {
      "cell_type": "code",
      "execution_count": 10,
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "wwGQgzKvQAda",
        "outputId": "9323f718-f0e5-4bbe-c229-55d6dd584be2"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "✅ 학습 함수 준비 완료\n",
            "CutMix 적용 확률: 50%\n",
            "Loss: Lovász 70% + CE 30%\n"
          ]
        }
      ],
      "source": [
        "import torch.optim as optim\n",
        "\n",
        "# Layer-wise LR: 인코더 1e-5, 디코더 1e-4\n",
        "encoder_params = [p for n, p in model.named_parameters() if 'segformer' in n]\n",
        "decoder_params = [p for n, p in model.named_parameters() if 'decode_head' in n]\n",
        "\n",
        "optimizer = optim.AdamW([\n",
        "    {'params': encoder_params, 'lr': 1e-5},  # pretrained 백본 → 작은 lr\n",
        "    {'params': decoder_params, 'lr': 1e-4},  # MLP 디코더 → 큰 lr\n",
        "], weight_decay=1e-2)\n",
        "\n",
        "NUM_EPOCHS = 40\n",
        "scheduler = optim.lr_scheduler.CosineAnnealingLR(\n",
        "    optimizer, T_max=NUM_EPOCHS, eta_min=1e-6\n",
        ")\n",
        "\n",
        "CUTMIX_PROB = 0.5  # 50% 확률로 CutMix 적용\n",
        "\n",
        "\n",
        "def compute_iou(pred, target, num_classes=6):\n",
        "    ious = []\n",
        "    pred   = pred.cpu().numpy()\n",
        "    target = target.cpu().numpy()\n",
        "    for cls in range(num_classes):\n",
        "        intersection = ((pred == cls) & (target == cls)).sum()\n",
        "        union        = ((pred == cls) | (target == cls)).sum()\n",
        "        ious.append(float('nan') if union == 0 else intersection / union)\n",
        "    return ious\n",
        "\n",
        "\n",
        "def train_one_epoch(model, loader, optimizer, device, use_cutmix=True):\n",
        "    model.train()\n",
        "    total_loss, n = 0.0, 0\n",
        "    pbar = tqdm(loader, desc='Train')\n",
        "    for imgs, masks in pbar:\n",
        "        imgs, masks = imgs.to(device), masks.to(device)\n",
        "\n",
        "        # CutMix 적용 (CUTMIX_PROB 확률)\n",
        "        if use_cutmix and np.random.random() < CUTMIX_PROB:\n",
        "            imgs, masks = cutmix_batch(imgs, masks, alpha=1.0)\n",
        "\n",
        "        outputs = model(pixel_values=imgs)\n",
        "        logits  = get_seg_logits(outputs, (IMG_H, IMG_W))\n",
        "        loss    = combined_loss(logits, masks)\n",
        "\n",
        "        optimizer.zero_grad()\n",
        "        loss.backward()\n",
        "        torch.nn.utils.clip_grad_norm_(model.parameters(), max_norm=1.0)  # 그래디언트 클리핑\n",
        "        optimizer.step()\n",
        "\n",
        "        total_loss += loss.item()\n",
        "        n += 1\n",
        "        pbar.set_postfix({'loss': f'{loss.item():.4f}'})\n",
        "    return total_loss / n\n",
        "\n",
        "\n",
        "def validate(model, loader, device, num_classes=6):\n",
        "    model.eval()\n",
        "    total_loss, n = 0.0, 0\n",
        "    all_ious = [[] for _ in range(num_classes)]\n",
        "\n",
        "    with torch.no_grad():\n",
        "        pbar = tqdm(loader, desc='Val')\n",
        "        for imgs, masks in pbar:\n",
        "            imgs, masks = imgs.to(device), masks.to(device)\n",
        "            outputs = model(pixel_values=imgs)\n",
        "            logits  = get_seg_logits(outputs, (IMG_H, IMG_W))\n",
        "            loss    = combined_loss(logits, masks)\n",
        "            preds   = logits.argmax(dim=1)\n",
        "\n",
        "            for iou, cls_ious in zip(compute_iou(preds, masks), all_ious[0:]):\n",
        "                pass\n",
        "            batch_ious = compute_iou(preds, masks, num_classes)\n",
        "            for cls, iou in enumerate(batch_ious):\n",
        "                if not (isinstance(iou, float) and np.isnan(iou)):\n",
        "                    all_ious[cls].append(iou)\n",
        "\n",
        "            total_loss += loss.item()\n",
        "            n += 1\n",
        "            pbar.set_postfix({'loss': f'{loss.item():.4f}'})\n",
        "\n",
        "    class_ious = [np.mean(x) if x else 0.0 for x in all_ious]\n",
        "    return total_loss / n, class_ious, np.mean(class_ious)\n",
        "\n",
        "\n",
        "print('✅ 학습 함수 준비 완료')\n",
        "print(f'CutMix 적용 확률: {CUTMIX_PROB*100:.0f}%')\n",
        "print(f'Loss: Lovász 70% + CE 30%')"
      ],
      "id": "wwGQgzKvQAda"
