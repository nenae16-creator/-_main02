      "source": [
        "# 🎯 Part 5: Lovász-Softmax Loss\n",
        "\n",
        "**왜 Lovász?**\n",
        "- CrossEntropy는 픽셀별 확률을 최적화 → IoU와 간접적으로만 연관\n",
        "- Lovász은 Jaccard loss(=IoU loss)의 convex surrogate → **IoU를 직접 최적화**\n",
        "- 특히 소수 클래스(Lane Mark)처럼 픽셀 수 불균형이 심할 때 효과적\n",
        "- 기존 Weighted CE와 달리 클래스 가중치 수동 튜닝 불필요"
      ],
      "id": "BRLWWaNyQAda"
    },
    {
      "cell_type": "code",
      "execution_count": 9,
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "sfDDvjx1QAda",
        "outputId": "d1c92d67-918a-4032-edd6-4b1cd19590dd"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "패키지 없음 → 인라인 구현 사용\n",
            "✅ Combined Loss 테스트: 1.2378\n"
          ]
        }
      ],
      "source": [
        "# Lovász-Softmax (설치된 패키지에서)\n",
        "try:\n",
        "    from lovasz_losses import lovasz_softmax\n",
        "    print('✅ lovász_losses 패키지 사용')\n",
        "except ImportError:\n",
        "    print('패키지 없음 → 인라인 구현 사용')\n",
        "\n",
        "    def lovasz_grad(gt_sorted):\n",
        "        \"\"\"Jaccard 그래디언트 계산\"\"\"\n",
        "        p = len(gt_sorted)\n",
        "        gts = gt_sorted.sum()\n",
        "        intersection = gts - gt_sorted.float().cumsum(0)\n",
        "        union = gts + (1 - gt_sorted).float().cumsum(0)\n",
        "        jaccard = 1. - intersection / union\n",
        "        if p > 1:\n",
        "            jaccard[1:p] = jaccard[1:p] - jaccard[0:-1]\n",
        "        return jaccard\n",
        "\n",
        "    def flatten_probas(probas, labels, ignore=None):\n",
        "        \"\"\"\n",
        "        4D (B,C,H,W) + 3D (B,H,W) → 2D (N,C) + 1D (N,)\n",
        "        3D (C,H,W) + 2D (H,W)도 지원 (per_image 내부용)\n",
        "        \"\"\"\n",
        "        if probas.dim() == 3:\n",
        "            # (C, H, W) → (1, C, H, W)\n",
        "            probas = probas.unsqueeze(0)\n",
        "        if labels.dim() == 2:\n",
        "            # (H, W) → (1, H, W)\n",
        "            labels = labels.unsqueeze(0)\n",
        "        B, C, H, W = probas.size()\n",
        "        probas = probas.permute(0, 2, 3, 1).contiguous().view(-1, C)\n",
        "        labels = labels.view(-1)\n",
        "        if ignore is not None:\n",
        "            valid = labels != ignore\n",
        "            probas = probas[valid]\n",
        "            labels = labels[valid]\n",
        "        return probas, labels\n",
        "\n",
        "    def lovasz_softmax_flat(probas, labels, classes='present'):\n",
        "        \"\"\"probas: (N, C), labels: (N,)\"\"\"\n",
        "        if probas.numel() == 0:\n",
        "            return probas * 0.\n",
        "        C = probas.size(1)\n",
        "        losses = []\n",
        "        class_to_sum = list(range(C)) if classes == 'all' else torch.unique(labels).tolist()\n",
        "        for c in class_to_sum:\n",
        "            fg = (labels == c).float()\n",
        "            if fg.sum() == 0 and classes == 'present':\n",
        "                continue\n",
        "            class_pred = probas[:, c]\n",
        "            errors = (fg - class_pred).abs()\n",
        "            errors_sorted, perm = torch.sort(errors, 0, descending=True)\n",
        "            fg_sorted = fg[perm.data]\n",
        "            losses.append(torch.dot(errors_sorted, lovasz_grad(fg_sorted)))\n",
        "        return torch.stack(losses).mean() if losses else torch.tensor(0.0, device=probas.device)\n",
        "\n",
        "    def lovasz_softmax(probas, labels, classes='present', per_image=False, ignore=None):\n",
        "        \"\"\"\n",
        "        probas: (B, C, H, W) softmax 확률\n",
        "        labels: (B, H, W) 정답 라벨\n",
        "        \"\"\"\n",
        "        if per_image:\n",
        "            loss = torch.stack([\n",
        "                lovasz_softmax_flat(*flatten_probas(p, l, ignore), classes=classes)\n",
        "                for p, l in zip(probas, labels)\n",
        "            ])\n",
        "            return loss.mean()\n",
        "        return lovasz_softmax_flat(*flatten_probas(probas, labels, ignore), classes=classes)\n",
        "\n",
        "\n",
        "def combined_loss(logits, targets, ce_weight=0.3, lov_weight=0.7):\n",
        "    \"\"\"\n",
        "    Lovász (70%) + CE (30%) 혼합\n",
        "    \"\"\"\n",
        "    probs = logits.softmax(dim=1)\n",
        "    loss_lov = lovasz_softmax(probs, targets, classes='present', per_image=True)\n",
        "    loss_ce  = F.cross_entropy(logits, targets)\n",
        "    return ce_weight * loss_ce + lov_weight * loss_lov\n",
        "\n",
        "\n",
        "# 테스트\n",
        "dummy_logits  = torch.randn(2, 6, 64, 64)\n",
        "dummy_targets = torch.randint(0, 6, (2, 64, 64))\n",
        "test_loss = combined_loss(dummy_logits, dummy_targets)\n",
        "print(f'✅ Combined Loss 테스트: {test_loss.item():.4f}')"
      ],
      "id": "sfDDvjx1QAda"
