        "SAVE_PATH = './best_model_segformer.pth'\n",
        "BEST_IOU  = 0.0\n",
        "history   = {'train_loss': [], 'val_loss': [], 'val_mIoU': [], 'class_iou': []}\n",
        "\n",
        "print(f'🚀 SegFormer + Lovász + CutMix 학습 시작! ({NUM_EPOCHS} epochs)\\n')\n",
        "\n",
        "for epoch in range(1, NUM_EPOCHS + 1):\n",
        "    print(f'\\n{\"=\"*60}\\n📍 Epoch {epoch}/{NUM_EPOCHS} | LR: {scheduler.get_last_lr()}\\n{\"=\"*60}')\n",
        "\n",
        "    train_loss = train_one_epoch(model, train_loader, optimizer, device)\n",
        "    val_loss, class_ious, mIoU = validate(model, val_loader, device)\n",
        "    scheduler.step()\n",
        "\n",
        "    history['train_loss'].append(train_loss)\n",
        "    history['val_loss'].append(val_loss)\n",
        "    history['val_mIoU'].append(mIoU)\n",
        "    history['class_iou'].append(class_ious)\n",
        "\n",
        "    print(f'\\nTrain Loss: {train_loss:.4f} | Val Loss: {val_loss:.4f} | mIoU: {mIoU:.4f}')\n",
        "    for i, (name, iou) in enumerate(zip(CLASS_NAMES, class_ious)):\n",
        "        marker = ' ⭐' if name == 'Lane Mark' else ''\n",
        "        print(f'   {i} {name:12s} {iou:.4f}{marker}')\n",
        "\n",
        "    if mIoU > BEST_IOU:\n",
        "        BEST_IOU = mIoU\n",
        "        torch.save({\n",
        "            'epoch': epoch,\n",
        "            'model_state_dict': model.state_dict(),\n",
        "            'optimizer_state_dict': optimizer.state_dict(),\n",
        "            'mIoU': mIoU,\n",
        "            'class_ious': class_ious,\n",
        "        }, SAVE_PATH)\n",
        "        print(f'   💾 최고 성능 갱신! mIoU={BEST_IOU:.4f}')\n",
        "\n",
