      "source": [
        "import cv2\n",
        "from collections import deque\n",
        "\n",
        "\n",
        "class HybridDangerAnalyzer:\n",
        "    \"\"\"\n",
        "    룰 기반 (즉각 반응) + LSTM (시계열 패턴) 앙상블 위험도 분석기\n",
        "    LSTM 가중치 0.6, 룰 기반 0.4으로 혼합\n",
        "    \"\"\"\n",
        "    def __init__(self, lstm_model, feat_extractor, seq_len=10, device='cpu',\n",
        "                 lstm_weight=0.6, rule_weight=0.4):\n",
        "        self.lstm_model    = lstm_model.eval()\n",
        "        self.feat_extractor = feat_extractor\n",
        "        self.seq_len       = seq_len\n",
        "        self.device        = device\n",
        "        self.lstm_weight   = lstm_weight\n",
        "        self.rule_weight   = rule_weight\n",
        "        self.frame_buffer  = deque(maxlen=seq_len)\n",
        "\n",
        "    def rule_score(self, mask):\n",
        "        H, W = mask.shape\n",
        "        score = 0\n",
        "        front_mv = (mask[H//3:2*H//3, W//3:2*W//3] == 5).mean()\n",
        "        if front_mv > 0.10:  score += min(100, front_mv * 300)\n",
        "        if (mask[H//3:2*H//3, :W//3] == 5).mean() > 0.08:  score += 30\n",
        "        if (mask[H//3:2*H//3, 2*W//3:] == 5).mean() > 0.08: score += 30\n",
        "        return min(100, score)\n",
        "\n",
        "    def analyze(self, mask, bio_data=None):\n",
        "        feat = self.feat_extractor.extract(mask, bio_data)\n",
        "        self.frame_buffer.append(feat)\n",
        "\n",
        "        rule_s = self.rule_score(mask)\n",
        "\n",
        "        if len(self.frame_buffer) == self.seq_len:\n",
        "            seq = torch.FloatTensor(np.stack(list(self.frame_buffer))).unsqueeze(0).to(self.device)\n",
        "            with torch.no_grad():\n",
        "                lstm_logits = self.lstm_model(seq)\n",
        "                lstm_probs  = lstm_logits.softmax(dim=-1)[0].cpu().numpy()\n",
        "            lstm_score = (lstm_probs[1]*33 + lstm_probs[2]*66 + lstm_probs[3]*100)\n",
        "            final_score = self.lstm_weight * lstm_score + self.rule_weight * rule_s\n",
        "            source = 'LSTM+Rule'\n",
        "        else:\n",
        "            final_score = rule_s\n",
        "            source = 'Rule only (버퍼 채우는 중)'\n",
        "\n",
        "        if final_score >= 70:   level = 'DANGER'\n",
        "        elif final_score >= 40: level = 'WARNING'\n",
        "        elif final_score >= 15: level = 'CAUTION'\n",
        "        else:                   level = 'SAFE'\n",
        "\n",
        "        return {'score': round(final_score, 1), 'level': level, 'source': source}\n",
        "\n",
        "\n",
        "lstm_model.load_state_dict(torch.load('./lstm_danger.pth'))\n",
        "analyzer = HybridDangerAnalyzer(\n",
        "    lstm_model=lstm_model, feat_extractor=feat_extractor,\n",
        "    seq_len=10, device=device\n",
        ")\n",
