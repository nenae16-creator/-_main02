        "# LSTM 학습 데이터 생성 (세그멘테이션 마스크 시퀀스 → 위험 레벨 라벨)\n",
        "def build_lstm_dataset(val_dataset, seg_model, feature_extractor, seq_len=10, device='cuda'):\n",
        "    \"\"\"\n",
        "    세그멘테이션 모델 예측 마스크 시퀀스를 슬라이딩 윈도우로 잘라\n",
        "    LSTM 학습 데이터 생성.\n",
        "    라벨은 룰 기반 위험도를 GT로 사용 (→ 실제 서비스에서는 전문가 라벨링 권장)\n",
        "    \"\"\"\n",
        "    from collections import deque\n",
        "\n",
        "    seg_model.eval()\n",
        "    sequences, labels = [], []\n",
        "    frame_buffer = deque(maxlen=seq_len)\n",
        "\n",
        "    def rule_based_label(mask):\n",
        "        front_mv = (mask[mask.shape[0]//3:2*mask.shape[0]//3,\n",
        "                        mask.shape[1]//3:2*mask.shape[1]//3] == 5).mean()\n",
        "        if front_mv > 0.15:  return 3  # DANGER\n",
        "        elif front_mv > 0.08: return 2  # WARNING\n",
        "        elif front_mv > 0.03: return 1  # CAUTION\n",
        "        else:                 return 0  # SAFE\n",
        "\n",
        "    with torch.no_grad():\n",
        "        for idx in tqdm(range(len(val_dataset)), desc='LSTM 데이터 생성'):\n",
        "            img_t, _ = val_dataset[idx]\n",
        "            output   = seg_model(pixel_values=img_t.unsqueeze(0).to(device))\n",
        "            logits   = get_seg_logits(output, (IMG_H, IMG_W))\n",
        "            pred_mask = logits.argmax(dim=1)[0].cpu().numpy()\n",
        "\n",
        "            feat  = feature_extractor.extract(pred_mask)\n",
        "            label = rule_based_label(pred_mask)\n",
        "            frame_buffer.append(feat)\n",
        "\n",
        "            if len(frame_buffer) == seq_len:\n",
        "                sequences.append(np.stack(list(frame_buffer)))\n",
        "                labels.append(label)\n",
        "\n",
        "    return (\n",
