        "import imageio\n",
        "\n",
        "# 기존 BiometricScenario 클래스 (동일)\n",
        "class BiometricScenario:\n",
        "    def __init__(self, total_frames=40, seed=42):\n",
        "        np.random.seed(seed)\n",
        "        self.total_frames = total_frames\n",
        "        self.phase1_end = int(total_frames * 0.25)\n",
        "        self.phase2_end = int(total_frames * 0.55)\n",
        "        self.hr = 72.0; self.fatigue = 10.0\n",
        "        self.activity = 45.0; self.focus = 90.0\n",
        "\n",
        "    def update(self, frame_idx, _):\n",
        "        if frame_idx < self.phase1_end:\n",
        "            target_hr, fat_rate = 72 + np.random.randn()*2, 0.1\n",
        "        elif frame_idx < self.phase2_end:\n",
        "            p = (frame_idx - self.phase1_end) / (self.phase2_end - self.phase1_end)\n",
        "            target_hr, fat_rate = 72 + p*70 + np.random.randn()*3, 1.2\n",
        "        else:\n",
        "            target_hr, fat_rate = 145 + np.random.randn()*5, 1.8\n",
        "\n",
        "        self.hr += (target_hr - self.hr) * 0.25\n",
        "        self.fatigue += fat_rate\n",
        "        self.hr      = np.clip(self.hr, 55, 180)\n",
        "        self.fatigue = np.clip(self.fatigue, 0, 100)\n",
        "        return {'hr': self.hr, 'fatigue': self.fatigue,\n",
        "                'activity': self.activity, 'focus': self.focus}\n",
        "\n",
        "\n",
        "model.eval()\n",
