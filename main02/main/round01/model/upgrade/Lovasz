      },
      "source": [
        "# 🔪 Part 3: CutMix 증강 Dataset\n",
        "\n",
        "**핵심 아이디어:** Lane Mark(1.4%)같은 소수 클래스 픽셀을 다른 이미지에 붙여넣어 인위적으로 빈도를 높임.\n",
        "\n",
        "배치 내 두 이미지를 랜덤 bbox로 혼합 → 소수 클래스가 포함된 이미지가 섞이면 해당 픽셀이 보존됨."
      ],
      "id": "Yd2EL4hdQAda"
    },
    {
      "cell_type": "code",
      "execution_count": 6,
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "c1I313hJQAda",
        "outputId": "cacc9024-9a5a-469a-944d-8a3367a3b232"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Train: 160장, Val: 40장\n",
            "입력 해상도: 512×512\n"
          ]
        }
      ],
      "source": [
        "import albumentations as A\n",
        "from albumentations.pytorch import ToTensorV2\n",
        "from torch.utils.data import Dataset, DataLoader\n",
        "import torch.nn.functional as F\n",
        "\n",
        "# SegFormer 권장 입력 크기\n",
        "IMG_H, IMG_W = 512, 512\n",
        "\n",
        "train_transform = A.Compose([\n",
        "    A.Resize(height=IMG_H, width=IMG_W),\n",
        "    A.HorizontalFlip(p=0.5),\n",
        "    # 야간 특화 증강\n",
        "    A.RandomGamma(gamma_limit=(60, 140), p=0.4),\n",
        "    A.RGBShift(r_shift_limit=15, g_shift_limit=10, b_shift_limit=20, p=0.3),\n",
        "    A.HueSaturationValue(hue_shift_limit=10, sat_shift_limit=20, val_shift_limit=15, p=0.3),\n",
        "    A.RandomBrightnessContrast(p=0.3),\n",
        "    A.Normalize(mean=(0.485,0.456,0.406), std=(0.229,0.224,0.225)),\n",
        "    ToTensorV2(),\n",
        "])\n",
        "\n",
        "val_transform = A.Compose([\n",
        "    A.Resize(height=IMG_H, width=IMG_W),\n",
        "    A.Normalize(mean=(0.485,0.456,0.406), std=(0.229,0.224,0.225)),\n",
        "    ToTensorV2(),\n",
        "])\n",
        "\n",
        "\n",
        "class MotorcycleDataset(Dataset):\n",
        "    def __init__(self, file_list, images_dir, masks_dir, transform=None):\n",
        "        self.file_list  = file_list\n",
        "        self.images_dir = images_dir\n",
        "        self.masks_dir  = masks_dir\n",
        "        self.transform  = transform\n",
        "\n",
        "    def __len__(self): return len(self.file_list)\n",
        "\n",
        "    def __getitem__(self, idx):\n",
        "        fname = self.file_list[idx]\n",
        "        image = np.array(Image.open(os.path.join(self.images_dir, fname)).convert('RGB'))\n",
        "        mask  = np.array(Image.open(os.path.join(self.masks_dir,  fname)))\n",
        "        mask[mask == 255] = 0\n",
        "        if self.transform:\n",
        "            aug   = self.transform(image=image, mask=mask)\n",
        "            image = aug['image']\n",
        "            mask  = aug['mask'].long()\n",
        "        return image, mask\n",
        "\n",
        "\n",
        "def cutmix_batch(images, masks, alpha=1.0):\n",
        "    \"\"\"\n",
        "    CutMix: 배치 내 두 이미지/마스크를 랜덤 bbox로 혼합.\n",
        "    소수 클래스(Lane Mark 등)가 포함된 이미지 쌍이 만나면 픽셀이 보존됨.\n",
        "    \"\"\"\n",
        "    B, C, H, W = images.shape\n",
        "    lam = np.random.beta(alpha, alpha)\n",
        "    rand_idx = torch.randperm(B)\n",
        "\n",
        "    # bbox 계산\n",
        "    cut_ratio = np.sqrt(1.0 - lam)\n",
        "    cut_h = int(H * cut_ratio)\n",
        "    cut_w = int(W * cut_ratio)\n",
        "    cx = np.random.randint(W)\n",
        "    cy = np.random.randint(H)\n",
        "    x1 = max(0, cx - cut_w // 2)\n",
        "    y1 = max(0, cy - cut_h // 2)\n",
        "    x2 = min(W, cx + cut_w // 2)\n",
        "    y2 = min(H, cy + cut_h // 2)\n",
        "\n",
        "    mixed_images = images.clone()\n",
        "    mixed_masks  = masks.clone()\n",
        "    mixed_images[:, :, y1:y2, x1:x2] = images[rand_idx, :, y1:y2, x1:x2]\n",
        "    mixed_masks[:,     y1:y2, x1:x2] = masks[rand_idx,    y1:y2, x1:x2]\n",
        "    return mixed_images, mixed_masks\n",
        "\n",
        "\n",
        "# Train/Val 분할\n",
        "all_filenames  = [img_info['file_name'] for img_info in coco_json['images']]\n",
        "valid_filenames = [\n",
        "    fn for fn in all_filenames\n",
        "    if os.path.exists(os.path.join(IMAGES_DIR, fn))\n",
        "    and os.path.exists(os.path.join(MASKS_DIR,  fn))\n",
        "]\n",
        "np.random.seed(42)\n",
        "shuffled   = np.random.permutation(valid_filenames)\n",
        "split_idx  = int(len(shuffled) * 0.8)\n",
        "train_files = shuffled[:split_idx].tolist()\n",
        "val_files   = shuffled[split_idx:].tolist()\n",
        "\n",
        "BATCH_SIZE   = 4  # SegFormer는 메모리 더 씀 (T4 기준 4~6 권장)\n",
        "train_dataset = MotorcycleDataset(train_files, IMAGES_DIR, MASKS_DIR, train_transform)\n",
        "val_dataset   = MotorcycleDataset(val_files,   IMAGES_DIR, MASKS_DIR, val_transform)\n",
        "train_loader  = DataLoader(train_dataset, batch_size=BATCH_SIZE, shuffle=True,  num_workers=2, pin_memory=True)\n",
        "val_loader    = DataLoader(val_dataset,   batch_size=BATCH_SIZE, shuffle=False, num_workers=2, pin_memory=True)\n",
        "\n",
        "print(f'Train: {len(train_dataset)}장, Val: {len(val_dataset)}장')\n",
        "print(f'입력 해상도: {IMG_H}×{IMG_W}')"
      ],
      "id": "c1I313hJQAda"
    },
    {
      "cell_type": "markdown",
