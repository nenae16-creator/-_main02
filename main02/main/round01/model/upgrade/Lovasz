        "import torch.nn as nn\n",
        "\n",
        "class DangerFeatureExtractor:\n",
        "    \"\"\"\n",
        "    세그멘테이션 마스크 → LSTM 입력 피처 벡터 변환\n",
        "    [클래스별 픽셀 비율 6개 + 영역별 위험 점수 9개 + 생체신호 3개] = 18차원\n",
        "    \"\"\"\n",
        "    def __init__(self, num_classes=6):\n",
        "        self.num_classes = num_classes\n",
        "\n",
        "    def extract(self, mask, bio_data=None):\n",
        "        H, W = mask.shape\n",
        "        total = H * W\n",
        "\n",
        "        # 6차원: 클래스별 픽셀 비율\n",
        "        class_ratios = np.array([\n",
        "            (mask == c).sum() / total for c in range(self.num_classes)\n",
        "        ])\n",
        "\n",
        "        # 9차원: 3×3 영역별 Moveable(5) 비율 (핵심 위험 지표)\n",
        "        third_h, third_w = H // 3, W // 3\n",
        "        region_scores = []\n",
        "        for r in range(3):\n",
        "            for c in range(3):\n",
        "                region = mask[r*third_h:(r+1)*third_h, c*third_w:(c+1)*third_w]\n",
        "                score  = (region == 5).mean()  # Moveable 비율\n",
        "                region_scores.append(score)\n",
        "        region_scores = np.array(region_scores)\n",
        "\n",
        "        # 3차원: 생체신호 (없으면 0으로 패딩)\n",
        "        if bio_data:\n",
        "            bio_vec = np.array([\n",
        "                bio_data.get('hr', 70) / 180.0,       # 정규화\n",
        "                bio_data.get('fatigue', 0) / 100.0,\n",
        "                bio_data.get('focus', 100) / 100.0,\n",
        "            ])\n",
        "        else:\n",
        "            bio_vec = np.array([70/180.0, 0.0, 1.0])\n",
        "\n",
        "        return np.concatenate([class_ratios, region_scores, bio_vec])  # (18,)\n",
        "\n",
        "\n",
        "class LSTMDangerPredictor(nn.Module):\n",
        "    \"\"\"\n",
        "    시계열 세그멘테이션 피처 → 위험도 점수 (0~1) 예측\n",
        "\n",
        "    입력: (batch, seq_len=10, feature_dim=18)\n",
        "    출력: (batch, 1) — 위험 확률\n",
        "    \"\"\"\n",
        "    def __init__(self, input_dim=18, hidden_dim=64, num_layers=2, dropout=0.3):\n",
        "        super().__init__()\n",
        "        self.lstm = nn.LSTM(\n",
        "            input_size=input_dim,\n",
        "            hidden_size=hidden_dim,\n",
        "            num_layers=num_layers,\n",
        "            batch_first=True,\n",
        "            dropout=dropout if num_layers > 1 else 0,\n",
        "            bidirectional=False,  # 실시간 추론이므로 단방향\n",
        "        )\n",
        "        self.classifier = nn.Sequential(\n",
        "            nn.Linear(hidden_dim, 32),\n",
        "            nn.ReLU(),\n",
        "            nn.Dropout(dropout),\n",
        "            nn.Linear(32, 4),  # 4개 위험 레벨: SAFE/CAUTION/WARNING/DANGER\n",
        "        )\n",
        "\n",
        "    def forward(self, x):\n",
        "        lstm_out, (h_n, _) = self.lstm(x)\n",
        "        last_hidden = h_n[-1]          # 마지막 레이어 hidden state\n",
        "        return self.classifier(last_hidden)\n",
        "\n",
        "    def predict_level(self, x):\n",
        "        \"\"\"추론 시 사용: 가장 높은 확률의 위험 레벨 반환\"\"\"\n",
        "        with torch.no_grad():\n",
        "            logits = self.forward(x)\n",
        "            probs  = logits.softmax(dim=-1)\n",
        "            level  = probs.argmax(dim=-1)\n",
        "        return level, probs\n",
        "\n",
